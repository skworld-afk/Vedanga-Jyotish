generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  role      UserRole   @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  dashboard Dashboard?
  profiles  Profile[]
}

model Dashboard {
  id                   String   @id @default(cuid())
  userId               String   @unique
  name                 String   @default("My Dashboard")
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model Visitor {
  id        String   @id @default(cuid())
  ip        String
  userAgent String?
  visitedAt DateTime @default(now())
}

model Profile {
  id           String      @id @default(cuid())
  userId       String
  birthName    String?
  displayName  String
  gender       Gender?
  placeName    String
  birthDate    DateTime
  birthTime    String?
  latitude     Decimal?    @db.Decimal(10, 7)
  longitude    Decimal?    @db.Decimal(10, 7)
  timezoneId   String?
  timezoneName String?
  utcOffset    Int?
  utcDateTime  DateTime?
  julianDay    Decimal?    @db.Decimal(18, 9)
  isPrimary    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  chart        Chart?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports      ReportJob[]
  varshphals   Varshphal[]

  @@index([userId])
  @@index([userId, isPrimary])
  @@index([latitude, longitude])
  @@index([placeName])
}
model Admin {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Chart {
  id           String             @id @default(cuid())
  profileId    String             @unique
  ayanamsa     String?
  planets      Json
  divisional   Json
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  ayanamsaDeg  Decimal?           @db.Decimal(10, 6)
  bhavaChalit  Json?
  houses       Json?
  moonChart    Json?
  panchang     Json?
  sunChart     Json?
  transit      Json?
  vimshottari  Json?
  ashtakavarga AshtakavargaCache?
  profile      Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dasha        DashaCache?
}

model DashaCache {
  id        String   @id @default(cuid())
  chartId   String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chart     Chart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
}

model AshtakavargaCache {
  id        String   @id @default(cuid())
  chartId   String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chart     Chart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
}

model Varshphal {
  id        String   @id @default(cuid())
  profileId String
  year      Int
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, year])
}

model ReportJob {
  id        String    @id @default(cuid())
  profileId String
  status    JobStatus @default(PENDING)
  reportUrl String?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@index([createdAt])
}

model LocationCache {
  id           String   @id @default(cuid())
  placeName    String   @unique
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  timezoneId   String
  timezoneName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TimezoneCache {
  id           String   @id @default(cuid())
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  dateKey      String
  utcOffset    Int
  timezoneId   String
  timezoneName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([latitude, longitude, dateKey])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserRole {
  USER
  ASTROLOGER
  ADMIN
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ChartType {
  RASI
  NORTH_INDIAN
  SOUTH_INDIAN
}
