{
  "name": "astro-saas",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "vercel-build": "pnpm prisma generate --schema=packages/db/prisma/schema.prisma && turbo run build"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.17.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "react-hook-form": "^7.78.0",
    "zod": "^4.4.3"
  }
}
